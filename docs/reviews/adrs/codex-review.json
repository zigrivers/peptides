  {
    "severity": "P1",
    "category": "coverage",
    "location": "docs/adrs/index.md",
    "description": "The ADR set records only 9 high-level decisions, but the PRD requires several implementation-critical tech-stack choices that are not captured as ADRs: transactional email, Web Push, scheduled jobs, monitoring/alerting, object storage for async exports, CI/CD, linting, validation, date/time handling, and client/server state strategy.",
    "suggestion": "Add ADRs or expand the ADR index for all implementation-blocking stack decisions required by docs/plan.md §§5.2.7, 5.5, 5.6, 5.7, 8.1, 8.2, 8.7."
  },
  {
    "severity": "P1",
    "category": "completeness",
    "location": "ADR-006: Railway Hosting",
    "description": "ADR-006 mentions cron-triggered reminders but does not decide the scheduled-job architecture needed for dose reminders, stale-order flagging, vial expiry checks, async exports, or audit-log retention purges.",
    "suggestion": "Add a scheduled jobs ADR covering Railway Cron or another runner, protected cron endpoints, job frequencies, retry/error policy, and required jobs from the PRD."
  },
  {
    "severity": "P1",
    "category": "coverage",
    "location": "Missing ADR: Transactional Email",
    "description": "The PRD requires email for managed-user invites, password reset, async export delivery, and dose reminder fallback, but no ADR selects an email provider or template strategy.",
    "suggestion": "Add an ADR selecting Resend/Postmark/etc., template approach, deliverability assumptions, and failure handling for required transactional emails."
  },
  {
    "severity": "P1",
    "category": "correctness",
    "location": "ADR-005: Consequences",
    "description": "The GramJS trade-off analysis understates the PRD's main Telegram risk. The ADR lists lock-in and rate limits, but the PRD treats MTProto session fragility as a v1 critical-path risk requiring feasibility validation and manual fallback.",
    "suggestion": "Update ADR-005 to include session invalidation, auth-code flow fragility, runtime feasibility gate, encrypted session recovery, explicit fallback mode, and test-account validation."
  },
  {
    "severity": "P1",
    "category": "completeness",
    "location": "ADR-005: Decision",
    "description": "The ADR chooses GramJS but does not specify how MTProto session strings are stored, encrypted, scoped, rotated, revoked, or excluded from export, even though the PRD requires AES-256 encrypted server-side storage and revocation on account deletion.",
    "suggestion": "Expand ADR-005 or add a Telegram session security ADR covering storage table, AES-256-GCM, key management, user scoping, API redaction, deletion/revocation, and integration tests."
  },
  {
    "severity": "P1",
    "category": "consistency",
    "location": "ADR-009 vs docs/domain-models/audit.md",
    "description": "ADR-009 says audit records are immutable but also says storage growth is mitigated by a 90-day rolling purge. The Audit domain says audit events can never be updated or deleted. The PRD separately requires 90-day audit retention.",
    "suggestion": "Clarify the invariant as append-only within the retention window, with deletion allowed only by scheduled retention policy, or update the domain model if audit events must be truly permanent."
  },
  {
    "severity": "P1",
    "category": "consistency",
    "location": "ADR-007: Consequences; docs/domain-models/tracker.md Dose Log",
    "description": "ADR-007 says offline sync conflicts are mitigated by idempotency keys, but the Tracker domain model has no idempotency key or client mutation ID on DoseLog. Only Ordering defines an idempotencyKey.",
    "suggestion": "Add a DoseLog idempotency field and define offline replay semantics for duplicate protocol/date submissions, batch logs, skipped doses, and same-day edits."
  },
  {
    "severity": "P1",
    "category": "completeness",
    "location": "ADR-001 and ADR-005",
    "description": "The PRD requires the ordering module to be architecturally isolatable so sourcing can be disabled without breaking reference/tracker flows. The monolith and GramJS ADRs do not define module boundaries or feature-flag/removal strategy.",
    "suggestion": "Add an ADR for bounded-context/module boundaries: Reference, Tracker, Reconstitution, Ordering, Auth, Audit, with Ordering isolated behind routes, services, permissions, and a feature flag."
  },
  {
    "severity": "P1",
    "category": "consistency",
    "location": "ADR-002/ADR-008 vs docs/domain-models/reference.md and reconstitution.md",
    "description": "ReconstitutionCalculator compares dose against Profile.maxDose, but the Reference Profile model stores dosingLow/dosingTypical/dosingHigh as strings and has no numeric maxDose. This undermines the safety-critical warning policy and testability promised by the ADRs.",
    "suggestion": "Update the domain model and database decision to use structured numeric dose range value objects with units, while retaining human-readable display text."
  },
  {
    "severity": "P2",
    "category": "correctness",
    "location": "ADR-004: Consequences",
    "description": "ADR-004 says Auth.js handles complex auth flows out-of-the-box, but the PRD/domain require custom password reset, invites, account deletion, data export, managed-user lifecycle, bcrypt policy, and RBAC enforcement.",
    "suggestion": "Revise ADR-004 to distinguish Auth.js-provided session/auth primitives from custom domain flows and list required custom tables/services."
  },
  {
    "severity": "P2",
    "category": "coverage",
    "location": "ADR-008: Testing Strategy",
    "description": "ADR-008 covers Vitest and Playwright but does not record required test/quality gates from the PRD: audit DB assertions, silent-failure E2E paths, Telegram send timing, offline sync tests, axe accessibility scans, Lighthouse, k6, and security/static scanning.",
    "suggestion": "Expand ADR-008 into a full verification strategy with required suites, coverage targets, CI gates, browser matrix, and hard-gate mappings."
  },
  {
    "severity": "P2",
    "category": "coverage",
    "location": "Missing ADR: Monitoring & Observability",
    "description": "The PRD says monitoring tooling is a tech-stack decision and requires P0 alerts within 15 minutes, uptime monitoring, backup verification, audit-write failure detection, and Telegram send failure visibility. No ADR records these choices.",
    "suggestion": "Add an observability ADR selecting error tracking, uptime monitoring, alert routing, PII scrubbing policy, health checks, and backup/audit failure alerts."
  },
  {
    "severity": "P2",
    "category": "completeness",
    "location": "Missing ADR: Data Export/Object Storage",
    "description": "The PRD requires JSON export, CSV export, async export generation for files >=10MB, emailed download links, and account deletion export generation. No ADR records where export artifacts live or how links are secured.",
    "suggestion": "Add an ADR for export architecture covering synchronous streaming, async storage provider, signed URL expiry, cleanup, email delivery, and deletion workflow."
  },
  {
    "severity": "P3",
    "category": "correctness",
    "location": "ADR-003: Consequences",
    "description": "ADR-003 says shadcn/ui is accessible by default via Radix UI, which overstates the guarantee. The PRD requires WCAG 2.1 AA for Delegated Participant flows plus axe and keyboard testing.",
    "suggestion": "Update the ADR to state that Radix/shadcn provide accessible primitives, but compliance depends on implementation and must be verified with automated and manual accessibility checks."
  }
]
