[
  {
    "severity": "P0",
    "category": "coverage",
    "location": "3. Tracker Module",
    "description": "The API exposes only single-dose logging and offline sync, but the PRD/domain require protocol create/edit/deactivate/pause/resume/clone/restart, cycle management, batch Log All Scheduled, skip/edit dose, site suggestion/history, outcome logging, dashboard reads, and reminders.",
    "suggestion": "Add explicit Server Actions/read endpoints for protocol CRUD and lifecycle, cycle CRUD, daily schedule/dashboard reads, batch dose logging, skip/edit dose, injection-site suggestions/history, outcome logs, adherence metrics, and reminder configuration."
  },
  {
    "severity": "P0",
    "category": "coverage",
    "location": "Reconstitution Module",
    "description": "No reconstitution or vial inventory contracts are specified despite the PRD calling the calculator safety-critical and the architecture linking dose logging to Vial.remainingMg.",
    "suggestion": "Add contracts for calculate reconstitution, record reconstitution/create vial, list active vials, update vial status/expiry, inventory depletion warnings, and vial selection/linking during dose logging."
  },
  {
    "severity": "P0",
    "category": "coverage",
    "location": "4. Ordering Module",
    "description": "Ordering contracts omit major required operations: Telegram MTProto setup/reauth, vendor configuration, vendor product catalog CRUD, order draft/cart creation, inventory-aware suggestions, manual fallback send, mark received, cancel order, stale-order update, and order history.",
    "suggestion": "Define the complete order lifecycle API from Telegram session setup through Draft, Sent, Confirmed, PaymentSent, Received, Cancelled, and Stale, including vendor/product management and fallback-mode fields."
  },
  {
    "severity": "P0",
    "category": "correctness",
    "location": "4.2 [POST] /actions/ordering/confirm-payment",
    "description": "The endpoint jumps directly to PAYMENT_SENT when walletAddress/confirmedTotal are submitted, but the PRD requires a hard safety gate where the address and amount are displayed together and explicitly acknowledged before Mark Payment Sent is enabled.",
    "suggestion": "Split this into at least two actions: capture vendor confirmation to transition Sent -> Confirmed, then acknowledge displayed wallet/amount and mark payment sent to transition Confirmed -> PaymentSent. Include acknowledgedAt, acknowledgedByUserId, and optional txId."
  },
  {
    "severity": "P1",
    "category": "coverage",
    "location": "2. Auth Module",
    "description": "Auth contracts omit login, logout, session/current-user, invite acceptance, password reset request/consume, change email, change password, onboarding state updates, data export, account deletion scheduling, cancellation, and deletion blocking rules.",
    "suggestion": "Add account-management contracts matching Auth domain entities: PasswordResetToken, AccountDeletionRequest, DataExportRequest, OnboardingState, and session lifecycle."
  },
  {
    "severity": "P1",
    "category": "coverage",
    "location": "Multi-User/Admin",
    "description": "The contract only supports sending an invite, but the PRD requires managed-user list, invite resend/cancel, invite status, deactivate/delete managed user, reset managed-user password, protocol assignment, and 7/30-day adherence visibility.",
    "suggestion": "Add Power User admin endpoints/actions for managed-user lifecycle, adherence reads, protocol assignment, invite resend/cancel, and deactivation/deletion workflows."
  },
  {
    "severity": "P1",
    "category": "coverage",
    "location": "Reference Module",
    "description": "The catalog API only lists Compound[] and does not expose compound profile detail pages, citations, dosing ranges, stacking notes, archived/profile-in-progress behavior, recently viewed, or sorting required by the PRD.",
    "suggestion": "Add catalog DTOs and endpoints for search/browse results and compound profile detail, including Profile, Citation, dosingLow/dosingTypical/dosingHigh, category tags, sourcing note, archived status, and profile completeness."
  },
  {
    "severity": "P1",
    "category": "correctness",
    "location": "3.1 [POST] /actions/tracker/log-dose",
    "description": "The request shape cannot represent skipped doses, scheduledDate, same-day edits, notes, vial linkage, or batch membership, all of which are required by the Tracker domain and PRD.",
    "suggestion": "Use a DoseLog DTO with protocolId, scheduledDate, status Logged|Skipped, amount, injectionSite optional by route, note, vialId optional, idempotencyKey, and server-derived loggedByUserId."
  },
  {
    "severity": "P1",
    "category": "correctness",
    "location": "3.1 [POST] /actions/tracker/log-dose responses",
    "description": "The contract returns 422 insufficient_inventory while saying the log is allowed. That makes a non-blocking warning look like a failed mutation and conflicts with the PRD's 'log anyway' inventory behavior.",
    "suggestion": "Return 200/201 with a warnings array such as warnings: [{code: 'no_active_vial'|'insufficient_inventory'}], and reserve 422 for blocked validation failures."
  },
  {
    "severity": "P1",
    "category": "correctness",
    "location": "3.1 [POST] /actions/tracker/log-dose and Error Catalog",
    "description": "The endpoint uses duplicate_log while the error catalog uses dose_already_logged, and the domain says the idempotency key is unique per user-scheduledDate-protocolId. The duplicate semantics are ambiguous.",
    "suggestion": "Standardize one code, define whether idempotent replay returns the original success or 409, and separately define the user-confirmed duplicate-log flow from the PRD."
  },
  {
    "severity": "P1",
    "category": "correctness",
    "location": "3.2 [POST] /api/sync",
    "description": "Offline sync only accepts DOSE_LOGGED with payload: {}, but the architecture requires Logged, Skipped, and Edited cases with vial adjustment, audit logging, and idempotency conflict handling.",
    "suggestion": "Define versioned event envelopes with eventId/idempotencyKey, type DOSE_LOGGED|DOSE_SKIPPED|DOSE_EDITED|DOSE_BATCH_LOGGED, typed payloads, occurredAt, clientTimezone, and per-event success/failure results."
  },
  {
    "severity": "P1",
    "category": "correctness",
    "location": "4.1 [POST] /actions/ordering/send-order",
    "description": "The request omits idempotencyKey despite the global rule and does not specify duplicate-send handling, even though the PRD requires protection against double-click/network retry duplicate Telegram sends.",
    "suggestion": "Require idempotencyKey or a deterministic duplicate-send guard, define replay behavior, and include vendorId/messageHash/timestamp checks for the PRD's 60-second duplicate warning."
  },
  {
    "severity": "P1",
    "category": "correctness",
    "location": "Auth requirements across all endpoints",
    "description": "Authorization is underspecified for owner versus managed-user access. Contracts do not define subjectUserId scoping, Power User acting on managed users, or IDOR prevention expectations.",
    "suggestion": "Add an authorization matrix per endpoint specifying actor role, subject user, managedBy relationship checks, forbidden cases, and whether subjectUserId is accepted or derived."
  },
  {
    "severity": "P1",
    "category": "readiness",
    "location": "6. Domain Error Catalog",
    "description": "The error catalog is too incomplete for parallel implementation. It omits common validation, not found, forbidden, invite, protocol, vial, order state, Telegram, export, and audit failure errors.",
    "suggestion": "Expand the catalog with canonical codes, HTTP/status mapping, retryability, user-facing recovery guidance, and field-level validation detail shape."
  },
  {
    "severity": "P1",
    "category": "readiness",
    "location": "Global Standards: Idempotency",
    "description": "Idempotency is required globally but the contract does not define the header name, payload field precedence, key format, scope, TTL, replay response, or conflict semantics.",
    "suggestion": "Specify a single Idempotency-Key header or field convention, UUID format, per-user/per-operation scope, storage duration, and whether successful replays return cached success or conflict."
  },
  {
    "severity": "P2",
    "category": "consistency",
    "location": "Enum fields across Auth/Tracker/Ordering",
    "description": "Wire enum casing is inconsistent with domain models: role uses MANAGED_USER while domain uses ManagedUser; ordering responses use SENT/PAYMENT_SENT while domain uses Sent/PaymentSent.",
    "suggestion": "Define canonical wire enums for UserRole, ProtocolStatus, DoseLogStatus, OrderStatus, AdministrationRoute, ScheduleFrequency, and units, then use them consistently in all contracts."
  },
  {
    "severity": "P2",
    "category": "consistency",
    "location": "5.1 [GET] /api/catalog response",
    "description": "Returning raw Compound[] is not sufficient or stable for frontend/backend parallel work because domain Compound lacks PRD fields like category, sourcing note, profile completeness, dosing context, and citation display shape.",
    "suggestion": "Define explicit CatalogItemDto and CompoundProfileDto instead of exposing domain entities directly."
  },
  {
    "severity": "P2",
    "category": "readiness",
    "location": "Server Action contracts",
    "description": "The document labels Server Actions as [POST] endpoints with HTTP status responses. Server Actions usually need typed success/error return contracts rather than REST-only status semantics.",
    "suggestion": "For each Server Action, specify the TypeScript input schema and discriminated union result shape, or clearly state that these are route handlers rather than actual Next.js Server Actions."
  },
  {
    "severity": "P2",
    "category": "correctness",
    "location": "Sensitive mutations and Audit domain",
    "description": "Contracts do not specify audit side effects or transaction behavior, despite architecture requiring audit writes for dose logs, protocol mutations, order transitions, auth/admin events, and rollback on audit failure.",
    "suggestion": "Add audit requirements per mutation: action name, category, resourceType/resourceId, actorUserId, subjectUserId where applicable, metadata, and rollback behavior when audit write fails."
  },
  {
    "severity": "P2",
    "category": "readiness",
    "location": "Common Error Response.details",
    "description": "Validation details are unspecified, so frontend and backend cannot independently implement field-level errors, forms, or retry logic reliably.",
    "suggestion": "Define details as a stable schema such as {fields: Record<string, string[]>, retryAfterSeconds?: number, warnings?: Warning[]} and use it consistently."
  }
]
