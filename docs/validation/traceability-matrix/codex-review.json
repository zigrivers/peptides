  },\n  {\n    \"severity\": \"P2\",\n    \"category\": \"correctness\",\n    \"location\": \"Wave 2\",\n    \"description\": \"Task numbering error: there are two sections labeled 'Task 2.1'.\",\n    \"suggestion\": \"Renumber the 'Protocol CRUD & Basic Dose Logging' task to Task 2.2.\"\n  },\n  {\n    \"severity\": \"P2\",\n    \"category\": \"executability\",\n    \"location\": \"Task 2.2\",\n    \"description\": \"Task 2.2 (Protocol CRUD & Dose Logging) is overloaded. These are two distinct complex features (Schedule generation vs Event logging).\",\n    \"suggestion\": \"Split Task 2.2 into 'Task 2.2: Protocol Management' and 'Task 2.4: Dose Logging & Inventory decrement'.\"\n  },\n  {\n    \"severity\": \"P2\",\n    \"category\": \"coverage\",\n    \"location\": \"Wave 2 / Wave 4\",\n    \"description\": \"US-TRK-06 and US-TRK-07 (Subjective Outcome Logging and Correlation Timeline) are missing.\",\n    \"suggestion\": \"Add a task to Wave 4 for 'Analytics & Outcome Tracking'.\"\n  },\n  {\n    \"severity\": \"P2\",\n    \"category\": \"coverage\",\n    \"location\": \"Wave 3\",\n    \"description\": \"US-ORD-05 (Receive Order) and US-ORD-07 (Order Status State Machine) are missing from the Ordering wave.\",\n    \"suggestion\": \"Add 'Order Receiving flow' and 'Status transition logic' to Task 3.3 or a new Task 3.4.\"\n  },\n  {\n    \"severity\": \"P3\",\n    \"category\": \"coverage\",\n    \"location\": \"Wave 4\",\n    \"description\": \"US-AUT-01 (Onboarding Path) is missing.\",\n    \"suggestion\": \"Add a task to Wave 4 for 'Role-specific Onboarding Wizards'.\"\n  }\n]",
