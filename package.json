{
  "name": "peptides",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "eval": "vitest run tests/evals",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm prisma:validate",
    "db:setup": "docker compose up -d && pnpm prisma migrate dev",
    "db:reset": "pnpm prisma migrate reset --force",
    "prisma:dev": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^3.0.3",
    "decimal.js": "^10.6.0",
    "next": "15.0.0-rc.0",
    "next-auth": "5.0.0-beta.31",
    "react": "19.0.0-rc.0",
    "react-dom": "19.0.0-rc.0",
    "resend": "^6.12.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.0.0-rc.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.8.0",
    "glob": "^13.0.6",
    "postcss": "^8.4.38",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
