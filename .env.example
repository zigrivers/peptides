# Local development environment variables
# Copy this to .env for local development

# Database
# Use the local docker-compose Postgres instance
DATABASE_URL="postgresql://dev:dev@localhost:5432/peptides_dev?schema=public"

# Auth.js
# Generate a random secret for local: openssl rand -base64 32
NEXTAUTH_SECRET="local-development-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"


# Telegram (Ordering Pillar)
# Get these from https://my.telegram.org
TELEGRAM_APP_ID=""
TELEGRAM_APP_HASH=""
TELEGRAM_SESSION_KEY="local-session-key-32-chars-long-!!"

# Email (Resend)
RESEND_API_KEY="re_123456789"

# Sentry (Observability)
SENTRY_DSN=""

# Cloudflare R2 (Exports)
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="peptides-exports-dev"

# Cron (Railway)
CRON_SECRET="local-cron-secret"

# Web Push (VAPID keys — see ADR-007).
# Generate with: npx web-push generate-vapid-keys
# Public key is exposed via GET /api/notifications/vapid-public-key for the
# client to register a subscription. Private key is server-only and used by
# the dispatcher (Task 5.2). When both are unset, the settings UI renders an
# email-only fallback.
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""

# AI (Vercel AI SDK — see ADR-010).
# Primary: Anthropic Claude. Secondary: Gemini.
# When BOTH keys are unset, AI-backed features (citation extraction, admin
# profile drafting) return an `ai_unavailable` error. AI failures NEVER
# block dose logging, ordering, or reconstitution flows.
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# Feature flags (per ADR-015)
# DISABLE_ORDERING: set to exact string "true" to disable the entire ordering
# module (routes return 404, server actions throw, cron is a no-op, UI hides
# ordering surfaces). Tracker/Reference/Reconstitution/Admin remain functional.
# Anything other than "true" leaves ordering ENABLED. See docs/operations-runbook.md §1.3.
DISABLE_ORDERING="false"
