# Local development environment variables
# Copy this to .env for local development

# Database
# Use the local docker-compose Postgres instance
DATABASE_URL="postgresql://dev:dev@localhost:5432/peptides_dev?schema=public"

# Auth.js (v5). v5 reads AUTH_SECRET; NEXTAUTH_SECRET is the legacy v4 name,
# kept here for back-compat. Set both to the same value.
# Generate a random secret: openssl rand -base64 33
AUTH_SECRET="local-development-secret-change-me"
NEXTAUTH_SECRET="local-development-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth. The app accepts these explicit names and also the Auth.js aliases
# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET. The login page hides Google sign-in unless
# both id and secret are configured.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"


# Telegram (Ordering Pillar)
# Get these from https://my.telegram.org
TELEGRAM_APP_ID=""
TELEGRAM_APP_HASH=""
TELEGRAM_SESSION_KEY="local-session-key-32-chars-long-!!"

# Email (Resend)
RESEND_API_KEY="re_123456789"

# Sentry (Observability)
SENTRY_DSN=""

# Cloudflare R2 (Exports)
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="peptides-exports-dev"

# Cron (Railway)
CRON_SECRET="local-cron-secret"

# Web Push (VAPID keys — see ADR-007).
# Generate with: npx web-push generate-vapid-keys
# Public key is exposed via GET /api/notifications/vapid-public-key for the
# client to register a subscription. Private key is server-only and used by
# the dispatcher (Task 5.2). When both are unset, the settings UI renders an
# email-only fallback.
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""

# AI (Vercel AI SDK — see ADR-010).
# Primary: Anthropic Claude. Secondary: Gemini. Tertiary: DeepSeek.
# Each key is optional; a provider with no key is skipped in the fall-through
# chain (Anthropic → Gemini → DeepSeek). When ALL keys are unset, AI-backed
# features (citation extraction, admin profile drafting, the monthly catalog
# refresh) return an `ai_unavailable` error. AI failures NEVER block dose
# logging, ordering, or reconstitution flows.
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
DEEPSEEK_API_KEY=""

# Feature flags (per ADR-015)
# DISABLE_ORDERING: set to exact string "true" to disable the entire ordering
# module (routes return 404, server actions throw, cron is a no-op, UI hides
# ordering surfaces). Tracker/Reference/Reconstitution/Admin remain functional.
# Anything other than "true" leaves ordering ENABLED. See docs/operations-runbook.md §1.3.
DISABLE_ORDERING="false"

# --- Compound Research (ADR-017) — local model + web search ---
# Feature is hidden/disabled unless this is "true" AND the local endpoint is reachable.
COMPOUND_RESEARCH_ENABLED="false"
# OpenAI-compatible base URL of the local orchestrator model (note the /v1 suffix).
LOCAL_LLM_BASE_URL="http://127.0.0.1:8001/v1"
# Most local servers ignore the key; a placeholder is fine.
LOCAL_LLM_API_KEY="not-needed"
# Optional: pin the model id. If unset, it is resolved at runtime from GET {base}/models.
LOCAL_LLM_MODEL=""
# Local reasoning models (e.g. Qwen3) emit slow "thinking" blocks; disable for speed.
# Set to "false" only if your local model is not a thinking model. Default: thinking disabled.
LOCAL_LLM_DISABLE_THINKING="true"
# Web search provider: "tavily" (default) or "ddg". Falls back to ddg automatically.
WEB_SEARCH_PROVIDER="tavily"
# Tavily API key (server-only, never sent to the client). If absent, ddg is used.
TAVILY_API_KEY=""